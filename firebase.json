{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "reference/**",
      "docs/**"
    ],
    "cleanUrls": false,
    "trailingSlash": false,
    "404": "/404.html"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
