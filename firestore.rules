rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ai/ collections — read public, write requires auth ──
    match /ai/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── academy/ collections — read public, write requires auth ──
    match /academy/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Tất cả collections còn lại — yêu cầu auth ──
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
