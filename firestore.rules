rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ai/ — read public, write requires auth ──
    match /ai/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── academy/ — read public, write requires auth ──
    match /academy/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── mes/ — read public, write requires auth ──
    match /mes/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── wms/ — read public, write requires auth ──
    match /wms/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── hr/ — read public, write requires auth ──
    match /hr/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Tất cả collections còn lại — yêu cầu auth ──
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
